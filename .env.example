# ── Credit Intel — Environment Configuration ──

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=8080
AI_ENGINE_PORT=8000

# Data storage
DATA_ROOT=/data

# SQLite database path
DB_PATH=/data/credit-intel.db

# Service URLs (Docker internal)
AI_ENGINE_BASE_URL=http://ai-engine:8000
BACKEND_BASE_URL=http://backend-go:8080

# Frontend → Backend (browser-side, localhost)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080

# Timeouts & CORS
BACKEND_HTTP_TIMEOUT_SEC=30
CORS_ALLOWED_ORIGINS=*

# AI Engine: search provider (mock for demo)
SEARCH_PROVIDER=mock
